<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>You Found A Thing</title>
<link href="https://fonts.googleapis.com/css2?family=Cinzel+Decorative:wght@400;700;900&family=Cinzel:wght@400;600;700&family=Crimson+Text:ital,wght@0,400;0,600;1,400;1,600&display=swap" rel="stylesheet">
<link rel="stylesheet" href="assets/css/loot-card-modal.css">
<link rel="stylesheet" href="assets/css/base.css">
<link rel="stylesheet" href="assets/css/scene.css">
<link rel="stylesheet" href="assets/css/cards.css">
<link rel="stylesheet" href="assets/css/effects.css">
<link rel="stylesheet" href="assets/css/responsive.css">
</head>
<body>
<!-- Atmospheric BG -->
<div id="dungeon-bg"></div>

<!-- Torches -->
<div class="torch torch-left">
  <div class="torch-glow"></div>
  <div class="torch-wall-bracket"></div>
  <div class="torch-head">
    <div class="torch-flame"></div>
  </div>
</div>
<div class="torch torch-right">
  <div class="torch-glow"></div>
  <div class="torch-wall-bracket"></div>
  <div class="torch-head">
    <div class="torch-flame"></div>
  </div>
</div>

<!-- Particles -->
<div id="particles"></div>

<!-- Screen flash -->
<div id="flash"></div>

<!-- Dim overlay -->
<div id="dim-overlay"></div>

<!-- Card detail modal -->
<div id="zoom-dim">
  <div id="card-modal"></div>
</div>

<!-- Main Stage -->
<div id="stage" class="flex-center-col">

  <!-- Chest -->
  <div id="chest-wrap" tabindex="0" role="button" aria-label="Open chest">
    <div id="chest-glow"></div>
    <img id="chest-img-closed"  class="abs-fill" src="assets/images/chest-closed.png"  alt="Closed chest"  draggable="false"/>
    <img id="chest-img-partial" class="abs-fill" src="assets/images/chest-partial.png" alt="Opening chest" draggable="false"/>
    <img id="chest-img-open"    class="abs-fill" src="assets/images/chest-open.png"    alt="Open chest"    draggable="false"/>
    <div id="chest-hint">✦ CLICK TO OPEN ✦</div>
  </div>

  <!-- Item slots -->
  <div id="slots-row"></div>

</div>

<!-- Card flip overlay -->
<div id="card-flip-wrap" class="flex-center-col">
  <!-- Light rays SVG -->
  <svg id="light-rays" class="abs-fill" viewBox="0 0 100 100">
    <g transform="translate(50,50)">
      <rect class="ray" x="0" y="-1.5" width="80" height="3" transform="rotate(0)" style="transform-origin:0 0"/>
      <rect class="ray" x="0" y="-1.5" width="80" height="3" transform="rotate(22.5)" style="transform-origin:0 0"/>
      <rect class="ray" x="0" y="-1.5" width="80" height="3" transform="rotate(45)" style="transform-origin:0 0"/>
      <rect class="ray" x="0" y="-1.5" width="80" height="3" transform="rotate(67.5)" style="transform-origin:0 0"/>
      <rect class="ray" x="0" y="-1.5" width="80" height="3" transform="rotate(90)" style="transform-origin:0 0"/>
      <rect class="ray" x="0" y="-1.5" width="80" height="3" transform="rotate(112.5)" style="transform-origin:0 0"/>
      <rect class="ray" x="0" y="-1.5" width="80" height="3" transform="rotate(135)" style="transform-origin:0 0"/>
      <rect class="ray" x="0" y="-1.5" width="80" height="3" transform="rotate(157.5)" style="transform-origin:0 0"/>
      <rect class="ray" x="0" y="-1.5" width="80" height="3" transform="rotate(180)" style="transform-origin:0 0"/>
      <rect class="ray" x="0" y="-1.5" width="80" height="3" transform="rotate(202.5)" style="transform-origin:0 0"/>
      <rect class="ray" x="0" y="-1.5" width="80" height="3" transform="rotate(225)" style="transform-origin:0 0"/>
      <rect class="ray" x="0" y="-1.5" width="80" height="3" transform="rotate(247.5)" style="transform-origin:0 0"/>
      <rect class="ray" x="0" y="-1.5" width="80" height="3" transform="rotate(270)" style="transform-origin:0 0"/>
      <rect class="ray" x="0" y="-1.5" width="80" height="3" transform="rotate(292.5)" style="transform-origin:0 0"/>
      <rect class="ray" x="0" y="-1.5" width="80" height="3" transform="rotate(315)" style="transform-origin:0 0"/>
      <rect class="ray" x="0" y="-1.5" width="80" height="3" transform="rotate(337.5)" style="transform-origin:0 0"/>
    </g>
  </svg>

  <div id="flip-card-scene">
    <div id="flip-card">
      <!-- Back -->
      <div class="card-face card-back abs-fill">
        <div class="card-back-symbol">✦</div>
        <div class="card-back-label">Rare...</div>
      </div>
      <!-- Front (legendary item) -->
      <div class="card-face card-front abs-fill">
        <div class="card-rarity-badge">Legendary</div>
        <div class="card-icon">🗡️</div>
        <div class="card-divider"></div>
        <div class="card-item-name">Cloak of Elvenkind</div>
        <div class="card-item-value">— gp</div>
        <div class="card-desc-divider"></div>
        <div class="card-item-desc">Once per long rest:<br>Turn invisible</div>
      </div>
    </div>
  </div>

  <div id="found-text">YOU FOUND A THING!</div>
</div>

<!-- Reset -->
<button id="reset-btn">✦ Open Another ✦</button>
<a href="loot-table.html" id="loot-table-btn" title="Loot Table" aria-label="Loot Table"><img src="assets/images/chest-closed.png" alt=""></a>

<script src="assets/js/loot-constants.js"></script>
<script src="assets/js/loot-display.js"></script>
<script src="assets/js/loot-audio.js"></script>
<script src="assets/js/loot-animation.js"></script>
<script>
(function() {

  // ── LOOT TABLE ──
  let LOOT = null; // loaded from loot-table.json or embedded when opened via file://

  function getEmbeddedLoot() {
    const items = [
      {id:0,name:'42 Gold',rarity:'Common',tier:1,category:'Treasure'},
      {id:1,name:'Healing Potion',rarity:'Common',tier:1,category:'Potion'},
      {id:2,name:'Shortsword',rarity:'Common',tier:1,category:'Weapon'},
      {id:3,name:'Cloak of Elvenkind ',rarity:'Legendary',tier:5,category:'Wondrous Item',description:'While wearing this cloak, Stealth checks made to hide are made with advantage.'},
    ];
    const by_tier = { '0': [0], '1': [0,1,2], '5': [3] };
    items.forEach((item, i) => { item._idx = i; });
    return { items, by_tier };
  }

  // Pick a random item from a given tier (or array of tiers)
  function pickFromTier(tiers) {
    if (!LOOT) return null;
    const tierArr = Array.isArray(tiers) ? tiers : [tiers];
    let pool = [];
    tierArr.forEach(t => {
      const ids = LOOT.by_tier[String(t)] || [];
      ids.forEach(id => pool.push(LOOT.items[id]));
    });
    if (!pool.length) return null;
    return pool[Math.floor(Math.random() * pool.length)];
  }

  // Build a chest roll: 3-4 mundane/common items + 1 reveal item at a given tier
  function rollChest(revealTier) {
    const mundaneCount = 3 + Math.floor(Math.random() * 2); // 3 or 4
    const mundane = [];
    for (let i = 0; i < mundaneCount; i++) {
      const item = pickFromTier([0, 1]); // Mundane + Common
      if (item) mundane.push(item);
    }
    // Card before the last (last mundane slot) has 50% chance of being uncommon
    if (mundane.length > 0 && Math.random() < 0.5) {
      let uncommonItem = pickFromTier(2);
      if (uncommonItem) {
        mundane[mundane.length - 1] = uncommonItem;
      } else {
        const last = mundane[mundane.length - 1];
        mundane[mundane.length - 1] = Object.assign({}, last, { rarity: 'Uncommon' });
      }
    }
    // Reveal item: pick from revealTier, fall back up if empty
    let reveal = null;
    for (let t = revealTier; t >= 2 && !reveal; t--) {
      reveal = pickFromTier(t);
    }
    if (!reveal) reveal = pickFromTier([2,3,4,5]);
    return { mundane, reveal };
  }

  // Current chest roll
  let currentRoll = null;

  // ── STATE ──
  let state = 'idle';

  const chestWrap  = document.getElementById('chest-wrap');
  const chestHint  = document.getElementById('chest-hint');
  const slotsRow   = document.getElementById('slots-row');
  const cardWrap   = document.getElementById('card-flip-wrap');
  const flipCard   = document.getElementById('flip-card');
  const cardFront  = flipCard.querySelector('.card-front');
  const cardBack   = flipCard.querySelector('.card-back');
  const foundText  = document.getElementById('found-text');
  const lightRays  = document.getElementById('light-rays');
  const flashEl    = document.getElementById('flash');
  const resetBtn   = document.getElementById('reset-btn');
  const dimOverlay = document.getElementById('dim-overlay');
  const zoomDim    = document.getElementById('zoom-dim');

  const cardModal = document.getElementById('card-modal');
  const particlesContainer = document.getElementById('particles');

  function wait(ms) { return new Promise(r => setTimeout(r, ms)); }

  function flipSlotFaceUp(slot) {
    const inner = slot.querySelector('.card-inner');
    if (!inner || inner.classList.contains('flipped')) return;
    playFlipSound();
    inner.classList.add('flipped');
  }

  function openCardModal(slot) {
    const item = slot._item;
    if (!item) return;
    const rm = RARITY_META[item.rarity] || RARITY_META['Common'];
    const frameBg = rm.frame ? `url('${rm.frame}'), linear-gradient(160deg, #1c1200 0%, #0d0900 100%)` : '';
    cardModal.style.backgroundImage = frameBg || '';
    cardModal.style.borderColor = rm.color;
    cardModal.style.boxShadow = `0 0 30px ${rm.glow}, 0 0 60px rgba(0,0,0,0.4)`;

    const desc = (item.properties || item.description || '').replace(/</g, '&lt;').replace(/\n/g, '<br>');
    const descBlock = desc
      ? `<div class="card-modal-desc-divider"></div><div class="card-modal-desc">${desc}</div>`
      : '';
    const reqHtml = item.requirements ? `<div class="card-modal-req">${item.requirements}</div>` : '';

    cardModal.innerHTML = `
      <div class="card-modal-content">
        <br>
        <div class="card-modal-rarity" style="color:${rm.color}">${item.rarity}</div>
        <div class="card-modal-icon">${itemIconHTML(item, 'clamp(3rem,9vw,5rem)')}</div>
        <div class="card-modal-divider"></div>
        <div class="card-modal-name">${item.name}</div>
        <div class="card-modal-value">${itemValueStr(item)}</div>
        ${descBlock}
        ${reqHtml}
      </div>
    `;
    zoomDim.classList.add('active');
  }

  function closeCardModal() {
    zoomDim.classList.remove('active');
    cardModal.innerHTML = '';
  }

  function buildCardBack(revealItem) {
    const rm = revealItem ? (RARITY_META[revealItem.rarity] || RARITY_META['Rare']) : RARITY_META['Rare'];
    const frameUrl = rm.frame ? `url('${rm.frame}')` : '';
    cardBack.style.backgroundImage = frameUrl ? `${frameUrl}, linear-gradient(135deg, #1a0830 0%, #0d0520 100%)` : '';
    cardBack.style.borderColor = rm.color;
    cardBack.style.boxShadow = `0 0 30px ${rm.glow}, 0 0 80px ${rm.glow.replace('0.8','0.3')}, inset 0 0 30px ${rm.glow.replace('0.8','0.1')}`;
    const labelEl = cardBack.querySelector('.card-back-label');
    if (labelEl) labelEl.textContent = (revealItem ? revealItem.rarity : 'Rare') + '…';
  }

  async function runReveal() {
    if (state !== 'idle') return;
    if (!LOOT) {
      chestHint.textContent = '⟳ Loading…';
      const isFileProtocol = window.location.protocol === 'file:';
      if (isFileProtocol) {
        // Avoid CORS when opening from file:// — use fallback so no fetch is attempted
        LOOT = getEmbeddedLoot();
        chestHint.textContent = '✦ CLICK TO OPEN ✦';
      } else {
        try {
          const res = await fetch('loot-table.json');
          if (!res.ok) throw new Error(res.statusText);
          LOOT = await res.json();
          const indexed = {};
          LOOT.items.forEach((item, i) => { item._idx = i; indexed[item.id] = i; });
          Object.keys(LOOT.by_tier).forEach(t => {
            LOOT.by_tier[t] = LOOT.by_tier[t].map(id => indexed[id]);
          });
          chestHint.textContent = '✦ CLICK TO OPEN ✦';
        } catch(e) {
          chestHint.textContent = '✦ CLICK TO OPEN ✦';
          console.warn('Could not load loot-table.json, using fallback');
          LOOT = getEmbeddedLoot();
        }
      }
    }

    // Roll this chest: 4 mundane + 1 reveal at tier 3-5
    const revealTier = 3 + Math.floor(Math.random() * 3); // 3, 4, or 5
    currentRoll = rollChest(revealTier);

    state = 'opening';

    // Shake the chest on click, then continue
    chestWrap.classList.add('chest-shake');
    await wait(2600);
    chestWrap.classList.remove('chest-shake');

    getAudioCtx();

    // Hide hint — fade out first, then stop the pulse animation once invisible
    chestHint.style.opacity = '0';
    chestWrap.style.cursor = 'default';
    setTimeout(() => { chestHint.style.animation = 'none'; }, 650);

    const imgClosed  = document.getElementById('chest-img-closed');
    const imgPartial = document.getElementById('chest-img-partial');
    const imgOpen    = document.getElementById('chest-img-open');

    // ── STAGE 1: Lid creaks open slightly ──
    playCreak();
    chestWrap.classList.add('lid-creak');
    spawnSparks(6, particlesContainer);

    // Quickly show the partial-open frame
    await wait(300);
    if (imgClosed)  imgClosed.style.opacity  = '0';
    if (imgPartial) imgPartial.style.opacity = '1';

    // Brief hold on partial
    await wait(250);

    // ── STAGE 2: Lid flings fully open ──
    chestWrap.classList.add('lid-open');
    if (imgPartial) imgPartial.style.opacity = '0';
    if (imgOpen)    imgOpen.style.opacity    = '1';
    spawnSparks(18, particlesContainer);
    await wait(300);

    // Brief beat — chest is open, light is pouring out, silence
    await wait(900);

    // ── STAGE 3: Items fly out one by one ──
    const pitches = [700, 820, 940, 1060];
    const mundaneItems = currentRoll ? currentRoll.mundane : [];

    // Pre-create all slots so we know their positions
    // Slots are invisible until the item lands
    for (let i = 0; i < mundaneItems.length; i++) {
      const slot = createSlot(mundaneItems[i], false, currentRoll);
      slot.style.opacity = '0';
      slot.style.transform = 'scale(0.8)';
      slotsRow.appendChild(slot);
    }

    // Mystery slot too
    const mysterySlot = createSlot(null, true, currentRoll);
    mysterySlot.style.opacity = '0';
    mysterySlot.style.transform = 'scale(0.8)';
    slotsRow.appendChild(mysterySlot);

    // Force layout so slots have real positions
    slotsRow.offsetHeight;

    // Now fly each item
    const allSlots = slotsRow.querySelectorAll('.item-slot');

    for (let i = 0; i < mundaneItems.length; i++) {
      const slot = allSlots[i];

      // Fly the item
      await flyItemToSlot(mundaneItems[i], slot, chestWrap);

      // Item lands — slot pops in (face-down; user clicks to flip)
      playPop(pitches[i]);
      spawnSparks(5, particlesContainer);
      slot.style.transition = 'opacity 0.12s ease, transform 0.35s cubic-bezier(0.34,1.56,0.64,1)';
      slot.style.opacity = '1';
      slot.style.transform = 'scale(1)';
      slot.classList.add('revealed');

      function handleSlotActivate(s) {
        const inner = s.querySelector('.card-inner');
        if (!inner) return;
        if (!inner.classList.contains('flipped')) {
          flipSlotFaceUp(s);
        } else {
          openCardModal(s);
        }
      }
      slot.addEventListener('click', () => handleSlotActivate(slot));
      slot.addEventListener('keydown', function(e) {
        if (e.key === 'Enter' || e.key === ' ') {
          e.preventDefault();
          handleSlotActivate(slot);
        }
      });

      await wait(480);
    }

    // Mystery slot flies out last — slower, more ominous
    await wait(300);
    const mystItem = { icon: '?', name: 'Unknown' };

    // Custom fly for mystery — slower
    await new Promise(resolve => {
      const chestRect = chestWrap.getBoundingClientRect();
      const slotRect  = mysterySlot.getBoundingClientRect();
      const startX = chestRect.left + chestRect.width / 2;
      const startY = chestRect.top + chestRect.height * 0.2;
      const endX   = slotRect.left + slotRect.width / 2;
      const endY   = slotRect.top  + slotRect.height / 2;
      const peakY  = Math.min(startY, endY) - window.innerHeight * 0.22;

      const flyer = document.createElement('div');
      flyer.className = 'flying-item';
      flyer.style.cssText = `left:${startX}px;top:${startY}px;transform:translate(-50%,-50%) scale(1.4);font-size:clamp(2rem,4.5vw,3.5rem);filter:drop-shadow(0 0 20px rgba(179,157,219,0.9))`;
      flyer.innerHTML = `<span style="color:rgba(179,157,219,0.8);font-family:'Cinzel Decorative',serif;animation:mystery-pulse 0.4s ease-in-out infinite alternate">?</span>`;
      document.body.appendChild(flyer);

      const steps = 80; // slower
      let frame = 0;
      const tick = () => {
        frame++;
        const t = frame / steps;
        const ease = t < 0.5 ? 2*t*t : -1+(4-2*t)*t;
        const bx = startX + (endX - startX) * t;
        const by = (1-t)*(1-t)*startY + 2*(1-t)*t*peakY + t*t*endY;
        const scale = 1.4 - 0.45 * ease;
        flyer.style.left = bx + 'px';
        flyer.style.top  = by + 'px';
        flyer.style.transform = `translate(-50%,-50%) scale(${scale})`;
        flyer.style.opacity = t > 0.8 ? (1 - (t-0.8)/0.2).toString() : '1';
        if (frame < steps) requestAnimationFrame(tick);
        else { flyer.remove(); resolve(); }
      };
      requestAnimationFrame(tick);
    });

    // Mystery slot lands — same as other cards: face-down, click to flip, click to zoom
    playPop(1040);
    spawnSparks(8, particlesContainer);
    mysterySlot.style.transition = 'opacity 0.12s ease, transform 0.4s cubic-bezier(0.34,1.56,0.64,1)';
    mysterySlot.style.opacity = '1';
    mysterySlot.style.transform = 'scale(1)';
    mysterySlot.classList.add('revealed');

    function handleMysterySlotActivate() {
      const inner = mysterySlot.querySelector('.card-inner');
      if (!inner) return;
      if (!inner.classList.contains('flipped')) {
        flipSlotFaceUp(mysterySlot);
      } else {
        openCardModal(mysterySlot);
      }
    }
    mysterySlot.addEventListener('click', handleMysterySlotActivate);
    mysterySlot.addEventListener('keydown', function(e) {
      if (e.key === 'Enter' || e.key === ' ') {
        e.preventDefault();
        handleMysterySlotActivate();
      }
    });

    state = 'done';
    await wait(800);
    resetBtn.classList.add('visible');
  }

  chestWrap.addEventListener('click', runReveal);
  chestWrap.addEventListener('keydown', function(e) {
    if (e.key === 'Enter' || e.key === ' ') {
      e.preventDefault();
      runReveal();
    }
  });

  zoomDim.addEventListener('click', () => closeCardModal());

  // Reset
  resetBtn.addEventListener('click', async () => {
    cardWrap.style.transition = 'opacity 0.4s';
    cardWrap.style.opacity = '0';
    await wait(400);

    cardWrap.classList.remove('visible');
    cardWrap.style.opacity = '';
    flipCard.classList.remove('flipped');
    foundText.classList.remove('appear');
    foundText.style.opacity = '0';
    lightRays.classList.remove('burst');
    flashEl.classList.remove('bang');
    chestWrap.classList.remove('lid-creak', 'lid-open');
    const imgC = document.getElementById('chest-img-closed');
    const imgP = document.getElementById('chest-img-partial');
    const imgO = document.getElementById('chest-img-open');
    if (imgC) { imgC.style.opacity = '1'; imgC.style.transition = 'none'; }
    if (imgP) { imgP.style.opacity = '0'; imgP.style.transition = 'none'; }
    if (imgO) { imgO.style.opacity = '0'; imgO.style.transition = 'none'; }
    requestAnimationFrame(() => {
      if (imgC) imgC.style.transition = '';
      if (imgP) imgP.style.transition = '';
      if (imgO) imgO.style.transition = '';
    });
    chestWrap.style.cursor = 'pointer';
    chestHint.style.animation = '';
    chestHint.style.opacity   = '';
    chestHint.style.transition = '';
    closeCardModal();
    slotsRow.innerHTML = '';
    resetBtn.classList.remove('visible');
    dimOverlay.classList.remove('active');
    dimOverlay.style.background = '';
    dimOverlay.style.transition = '';
    state = 'idle';
  });

  // Ambient sparks from torches
  setInterval(() => {
    if (Math.random() > 0.6) spawnSparks(1, particlesContainer);
  }, 800);

  // Idle detection: pause ambient animations after 3s of no input (performance)
  var idleTimer = null;
  var idleDelay = 3000;
  function goIdle() {
    document.body.classList.add('idle');
    idleTimer = null;
  }
  function clearIdle() {
    document.body.classList.remove('idle');
    if (idleTimer) clearTimeout(idleTimer);
    idleTimer = setTimeout(goIdle, idleDelay);
  }
  idleTimer = setTimeout(goIdle, idleDelay);
  document.body.addEventListener('mousemove', clearIdle, { passive: true });
  document.body.addEventListener('keydown', clearIdle, { passive: true });
  document.body.addEventListener('touchstart', clearIdle, { passive: true });
  document.body.addEventListener('scroll', clearIdle, { passive: true });

})();
</script>
</body>
</html>